{
  "name": "iam-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Unified identity, authentication, session, security, authorization, application, and audit platform.",
  "license": "UNLICENSED",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": "24.15.0",
    "pnpm": "11.11.0"
  },
  "scripts": {
    "architecture:check": "turbo run architecture:check",
    "build": "turbo run build",
    "contracts:check": "turbo run contracts:check",
    "dev": "turbo run dev",
    "format": "prettier --write . --ignore-unknown",
    "format:check": "prettier --check . --ignore-unknown",
    "lint": "eslint eslint.config.mjs prettier.config.mjs && turbo run lint",
    "lint:root": "eslint eslint.config.mjs prettier.config.mjs",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "test:integration": "turbo run test:integration",
    "typecheck": "turbo run typecheck"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.7.0",
    "prettier": "3.9.4",
    "turbo": "2.10.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0"
  }
}
